# ANTI-API Configuration
# Copia este archivo como .env y edita los valores
# ══════════════════════════════════════════════════════

# API Key para acceso externo (OpenCloud, bots, etc.)
# Genera una con: python -c "import uuid; print(uuid.uuid4().hex)"
ANTI_API_KEY=CAMBIA_ESTO_POR_TU_KEY

# Host y puerto
ANTI_API_HOST=0.0.0.0
ANTI_API_PORT=4000

# Máximo de navegadores paralelos por batch
ANTI_API_MAX_PARALLEL=10
